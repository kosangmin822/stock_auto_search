# Trading-only KIS settings
KIS_API_KEY=your_api_key_here
KIS_SECRET_KEY=your_secret_key_here
KIS_ACCOUNT_NUMBER=your_account_number_here
KIS_ACCOUNT_TYPE=your_account_type_here
KIS_BASE_URL=https://openapivts.koreainvestment.com:29443

# Search/report defaults
DEFAULT_MARKET=ALL
DEFAULT_LOOKBACK_DAYS=365
DEFAULT_REPORT_LIMIT=5

# Notifications
ALERT_WEBHOOK_URL=
ALERT_OUTPUT_FILE=data/alerts/notifications.log
ALERT_CONSOLE_ENABLED=true

# Logging
LOG_LEVEL=INFO
